<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="gnome-shell-extensions">
  <schema id="org.gnome.shell.extensions.user-corner-label"
          path="/org/gnome/shell/extensions/user-corner-label/">
    <key name="display-text" type="s">
      <default>''</default>
      <summary>Texto a mostrar (vazio = utilizador do sistema)</summary>
